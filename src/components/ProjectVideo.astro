---
/**
 * Project main video — conditional priority:
 *
 *   1. mainVideo (self-hosted main.mp4 in the project folder)  — highest fidelity
 *   2. bunny (Bunny CDN URL, phase 2)
 *   3. youtube (YouTube embed)
 *   4. poster image only
 *   5. nothing
 *
 * Renders nothing if none of the above is available — no dead UI.
 */

export interface Props {
  mainVideo?: string;
  bunny?: string;
  youtube?: string;
  poster?: string;
  title: string;
}

const { mainVideo, bunny, youtube, poster, title } = Astro.props;

function youtubeId(url: string): string | undefined {
  const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|v\/))([\w-]{11})/);
  return m?.[1] ?? (/^[\w-]{11}$/.test(url) ? url : undefined);
}

const ytId = youtube ? youtubeId(youtube) : undefined;
const ytEmbed = ytId ? `https://www.youtube-nocookie.com/embed/${ytId}?rel=0&modestbranding=1` : undefined;

const hasAny = Boolean(mainVideo || bunny || ytEmbed || poster);
---

{hasAny && (
  <div class="pv">
    {(mainVideo || bunny) ? (
      <video class="pv__video" controls preload="metadata" poster={poster}>
        <source src={(mainVideo ?? bunny)!} type="video/mp4" />
        Your browser doesn't support embedded video.
      </video>
    ) : ytEmbed ? (
      <iframe
        class="pv__frame"
        src={ytEmbed}
        title={title}
        width="100%"
        height="100%"
        frameborder="0"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    ) : (
      <img class="pv__poster" src={poster} alt={title} />
    )}
  </div>
)}

<style>
  .pv {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border: 1px solid var(--c-rule);
    overflow: hidden;
  }
  .pv__video,
  .pv__frame,
  .pv__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: cover;
  }
</style>
