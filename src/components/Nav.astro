---
/**
 * Floating nav for CHRONICA3000.
 *
 * Layout:
 *   [ chronica logo ]   [ ← back ]                              [ nav links ]
 *           left          left (inner pages only)                   right
 *
 * Variants:
 *   - variant="float"  — used on homepage; transparent, no black bar, no border.
 *   - variant="solid"  — used on inner pages; black background, subtle bottom rule.
 *
 * Current page is auto-detected and that link is suppressed.
 * Archive stays in the nav per brief.
 */

export interface Props {
  variant?: 'float' | 'solid';
  showBack?: boolean;
  backFallback?: string;
}

const { variant = 'solid', showBack = false, backFallback = '/works' } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';

const links: Array<{ label: string; href: string; match: (p: string) => boolean }> = [
  { label: 'works',      href: '/works',    match: (p) => p === '/works' },
  { label: 'archive',    href: '/archive',  match: (p) => p === '/archive' },
  { label: 'contact us', href: '/#contact', match: (_p) => false },
];
const visibleLinks = links.filter((l) => !l.match(path));
const isHome = path === '/';
---

<header class:list={['nav', variant === 'float' ? 'is-float' : 'is-solid']}>
  <div class="nav__inner">
    <div class="nav__left">
      <a href="/" class="nav__logo" aria-current={isHome ? 'page' : undefined} aria-label="chronica — home">
        <img src="/img/chronica-mark.png" alt="chronica" width="60" height="14" />
      </a>
      {showBack && (
        <a href={backFallback} class="nav__back" data-back-link data-fallback={backFallback}>
          <span aria-hidden="true">←</span>
          <span class="nav__back-text">back</span>
        </a>
      )}
    </div>

    <nav class="nav__links" aria-label="Primary">
      <ul>
        {visibleLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

{showBack && (
  <script is:inline>
    (function () {
      var KEY = 'chronica:lastList';
      var link = document.querySelector('[data-back-link]');
      if (!link) return;
      var fallback = link.getAttribute('data-fallback') || '/works';
      var stored = null;
      try { stored = sessionStorage.getItem(KEY); } catch (e) {}

      var target = stored;
      if (!target && document.referrer) {
        try {
          var u = new URL(document.referrer);
          if (u.origin === location.origin && /^\/(works|archive|$)/.test(u.pathname)) {
            target = u.pathname;
          }
        } catch (e) {}
      }
      if (target) link.setAttribute('href', target);

      link.addEventListener('click', function (e) {
        if (history.length > 1 && document.referrer) {
          try {
            var u = new URL(document.referrer);
            if (u.origin === location.origin && /^\/(works|archive|$)/.test(u.pathname)) {
              e.preventDefault();
              history.back();
            }
          } catch (err) {}
        }
      });
    })();
  </script>
)}

<script is:inline>
  /*
   * "contact us" navigation — glide to #contact and STAY there.
   *
   * Works on every page that renders a #contact element (homepage + all
   * internal pages — ContactSection is rendered everywhere). If the current
   * page has no #contact, the click is left alone and navigates to /#contact
   * as a normal anchor (BaseLayout's head script lands it with no flash).
   *
   * ── ROOT CAUSE of the old snap-back ──────────────────────────────────────
   * Every homepage section is `scroll-snap-stop: always` under
   * `scroll-snap-type: y mandatory`. The previous code glided by turning
   * scroll-snap-type OFF, animating, then turning it back ON. On iOS Safari
   * (WebKit), turning snap-type back ON re-runs the snap pass and REFUSES a
   * scroll position that jumped over `scroll-snap-stop: always` sections — it
   * re-commits to the last section it considers legitimately stopped at, i.e.
   * the highlight you came from. That is the visible jump-back. (Blink/desktop
   * Chrome does not enforce this, which is why it only reproduced on iPhone.)
   *
   * ── FIX ──────────────────────────────────────────────────────────────────
   * Never toggle scroll-snap-type. Instead:
   *   1. Relax `scroll-snap-stop` from `always` → `normal` on the sections for
   *      the duration of the glide, so the snap engine lets us travel straight
   *      to #contact instead of being yanked to an intermediate stop.
   *   2. Use native scrollIntoView (smooth) — with snap-type left ON, the
   *      engine glides and COMMITS #contact as the resting/active snap section.
   *   3. After the scroll settles, restore `scroll-snap-stop: always` and
   *      re-assert #contact once (idempotent) so we are guaranteed committed.
   * Because scroll-snap-type is never turned off→on, WebKit has nothing to
   * re-snap, so there is no jump-back.
   *
   * prefers-reduced-motion: jump instantly (no smooth animation).
   */
  (function () {
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var navigating = false;

    // Relax / restore scroll-snap-stop on the homepage sections.
    function relaxStops(relax) {
      var secs = document.querySelectorAll('main > section');
      for (var i = 0; i < secs.length; i++) {
        secs[i].style.scrollSnapStop = relax ? 'normal' : '';
      }
    }

    function goToContact(target) {
      if (navigating) return;
      navigating = true;

      // Clear any stored "return to this list/highlight" state so nothing can
      // restore the previous section after we land on Contact.
      try { sessionStorage.removeItem('chronica:lastList'); } catch (e) {}

      relaxStops(true);
      // Snap-type stays ON. The engine commits #contact; no re-snap-back.
      target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
      // Make Contact the active section in the URL.
      try { history.replaceState(null, '', '#contact'); } catch (e) {}

      // Settle: restore snap-stop and guarantee we are committed to Contact.
      var settled = false;
      function settle() {
        if (settled) return;
        settled = true;
        relaxStops(false);
        target.scrollIntoView({ block: 'start' }); // idempotent re-assert
        navigating = false;
      }
      // scrollend is the precise signal where supported; always keep a
      // timeout fallback (Safari only shipped scrollend recently).
      var scroller = document.querySelector('html.page-home main') || window;
      try {
        scroller.addEventListener('scrollend', function onEnd() {
          scroller.removeEventListener('scrollend', onEnd);
          settle();
        }, { once: true });
      } catch (e) {}
      setTimeout(settle, reduceMotion ? 50 : 1000);
    }

    document.querySelectorAll('a[href$="#contact"]').forEach(function (link) {
      link.addEventListener('click', function (e) {
        var target = document.getElementById('contact');
        if (!target) return;                     // no local #contact → let the link navigate
        e.preventDefault();
        goToContact(target);
      });
    });
  })();
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-nav);
    padding: clamp(16px, 1.8vw, 24px) var(--gutter);
    transition: background var(--dur) var(--ease);
  }

  /* Both variants float over the page now — no bar, no border, no background.
     Float variant keeps a gradient veil for legibility over the homepage reel.
     Solid variant (inner pages) is pure transparent — page background is #000
     so nav text reads cleanly without any chrome. */
  .nav.is-float {
    background: transparent;
    background-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .nav.is-solid {
    background: transparent;
  }

  .nav__inner {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--gap-m);
  }

  .nav__left {
    display: flex;
    align-items: center;
    gap: clamp(14px, 1.8vw, 28px);
    min-height: 1.2em;
  }

  /* Logo — small white wordmark. The PNG is white-on-transparent so it
     sits cleanly on any frame of the reel. */
  .nav__logo {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .nav__logo img {
    display: block;
    height: 14px;
    width: auto;
    object-fit: contain;
    transition: opacity var(--dur-fast) var(--ease);
  }
  .nav__logo:hover img { opacity: 0.8; }
  .nav__logo:focus-visible { outline: 1px solid #fff; outline-offset: 6px; }

  .nav__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-sm);
    color: rgba(232, 232, 232, 0.75);
    text-transform: lowercase;
  }
  .nav__back:hover { color: #fff; }

  .nav__links ul {
    display: flex;
    align-items: center;
    gap: clamp(18px, 2.4vw, 36px);
  }
  .nav__links a {
    font-size: var(--fs-sm);
    color: rgba(232, 232, 232, 0.75);
    text-transform: lowercase;
    letter-spacing: 0;
  }
  .nav__links a:hover { color: #fff; }

  @media (max-width: 520px) {
    .nav__back-text { display: none; }
    .nav__links ul { gap: 14px; }
    .nav__left { gap: 12px; }
    .nav__logo img { height: 12px; }
  }
</style>
