---
/**
 * /works — Tilda-correlated visual DNA on a REAL responsive CSS grid.
 *
 * Layout:
 *   [page header: "[works]" + count]
 *   [category-1] label
 *     <grid: 3 / 2 / 1 columns based on viewport>
 *       project tile (aspect 536/369, object-fit cover, caption overlay)
 *       …
 *   [category-2] label
 *     <grid>
 *
 * No filter chips, no absolute positioning, no transform-scaled mobile.
 * Whole tile is clickable. Posters resolve through bestPoster().
 */

import type { CategoryGroup, Project } from '../lib/projects';
import { bestPoster, getProjectMedia } from '../lib/projectAssets';

export interface Props {
  groups: CategoryGroup[];
  total?: number;  // kept for API back-compat, no longer rendered
}

const { groups } = Astro.props;
---

<section class="works-page">
  {/* No page header — only category labels per brief */}
  {groups.map((g) => (
    <section class="cat" aria-label={g.name}>
      <h2 class="cat__label container">[{g.name}]</h2>
      <ol class="cat__grid container">
        {g.projects.map((p: Project) => {
          const poster = bestPoster(p.data.slug, p.data.video.youtube);
          const hoverVideo = getProjectMedia(p.data.slug).hoverVideo;
          const href = p.data.hasPage ? `/${p.data.slug}` : undefined;
          const Tag = href ? 'a' : 'div';
          return (
            <li class="tile">
              <Tag class:list={['tile__link', !href && 'is-static']} href={href} data-source="works">
                <div class="tile__media">
                  {poster ? (
                    <img class="tile__img" src={poster} alt={p.data.title} loading="lazy" />
                  ) : (
                    <div class="tile__placeholder" aria-hidden="true">
                      <span>{p.data.slug}</span>
                    </div>
                  )}
                  {hoverVideo && (
                    <video
                      class="tile__hover"
                      src={hoverVideo}
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      aria-hidden="true"
                    ></video>
                  )}
                  <div class="tile__veil" aria-hidden="true"></div>
                </div>
                <div class="tile__caption">
                  <span class="tile__title">{p.data.title}</span>
                </div>
              </Tag>
            </li>
          );
        })}
      </ol>
    </section>
  ))}
</section>

<script is:inline>
  document.querySelectorAll('[data-source="works"]').forEach(function (el) {
    el.addEventListener('click', function () {
      try { sessionStorage.setItem('chronica:lastList', '/works'); } catch (e) {}
    });
  });

  /*
   * Works tile hover-video preview.
   * - Skips touch devices (no hover state on coarse pointers).
   * - Skips reduced-motion users.
   * - play().catch() swallows the rare autoplay-policy rejection silently.
   * - On leave: pause + rewind to first frame so next hover starts clean.
   */
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(hover: none)').matches) return;

    document.querySelectorAll('.tile').forEach(function (tile) {
      var video = tile.querySelector('.tile__hover');
      if (!video) return;

      var play = function () {
        try { video.play().catch(function () {}); } catch (e) {}
      };
      var stop = function () {
        try { video.pause(); video.currentTime = 0; } catch (e) {}
      };

      tile.addEventListener('pointerenter', play);
      tile.addEventListener('pointerleave', stop);
      tile.addEventListener('focusin', play);
      tile.addEventListener('focusout', stop);
    });
  })();
</script>

<style>
  .works-page {
    /* Sits below the solid nav. */
    padding-top: clamp(96px, 14vh, 160px);
    padding-bottom: clamp(80px, 12vw, 160px);
    background: var(--c-bg);
    color: #fff;
  }

  /* ---- category section ---- */
  .cat + .cat { margin-top: clamp(56px, 8vw, 100px); }

  .cat__label {
    font-family: 'Roboto Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 20px;
    line-height: 31px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 45px;
  }

  /* ---- responsive grid: 3 / 2 / 1 columns ---- */
  .cat__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    list-style: none;
    padding-inline: var(--gutter);
  }
  @media (max-width: 1279px) {
    .cat__grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }
  @media (max-width: 767px) {
    .cat__grid { grid-template-columns: 1fr; gap: 16px; }
    .cat__label { font-size: 18px; line-height: 28px; margin-bottom: 28px; }
  }

  /* ---- tile ---- */
  .tile {
    position: relative;
  }
  .tile__link {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 536 / 369;
    overflow: hidden;
    color: inherit;
    background: var(--c-bg-soft);
  }
  .tile__link.is-static { cursor: default; }

  .tile__media {
    position: absolute;
    inset: 0;
  }
  .tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 600ms var(--ease);
    filter: saturate(0.95) contrast(1.02);
  }
  .tile__link:hover .tile__img {
    transform: scale(1.03);
  }

  .tile__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.35);
    font-family: 'Roboto Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: repeating-linear-gradient(45deg, transparent 0 8px, rgba(255,255,255,0.025) 8px 9px);
  }

  /* Hover video — sits above the poster, fades in on hover. */
  .tile__hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 300ms ease;
    pointer-events: none;
    filter: saturate(0.95) contrast(1.02);
  }
  .tile__link:hover .tile__hover,
  .tile__link:focus-visible .tile__hover {
    opacity: 1;
  }
  /* Touch / reduced-motion: never show the hover video */
  @media (hover: none), (prefers-reduced-motion: reduce) {
    .tile__hover { display: none; }
  }

  /* Subtle gradient so caption reads against any image. */
  .tile__veil {
    position: absolute;
    inset: auto 0 0 0;
    height: 55%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }

  .tile__caption {
    position: absolute;
    left: 32px;
    bottom: 28px;
    right: 32px;          /* don't run into the right edge on narrow tiles */
    z-index: 2;
    display: flex;
    flex-direction: column;
    /* belt-and-suspenders legibility — even where the gradient is weak. */
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
  }
  .tile__title {
    font-family: 'Roboto Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(13px, 1.1vw, 16px);
    line-height: 1.35;
    font-weight: 400;
    letter-spacing: 0;
    color: #ffffff;
    /* No uppercase transform — titles in project.json already contain their case. */
  }

  /* Mobile: keep readable but proportional. */
  @media (max-width: 767px) {
    .tile__caption { left: 20px; right: 20px; bottom: 20px; }
    .tile__title   { font-size: 14px; }
  }
</style>
