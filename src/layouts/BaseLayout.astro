---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Open Graph preview image — absolute or root-relative path. */
  ogImage?: string;
  /** Apply theme-color = bg so mobile chrome matches. */
  matchChrome?: boolean;
  /** Class applied to <html>. Pages opt into page-scoped behaviour (e.g. scroll-snap). */
  pageClass?: string;
}

const {
  title = 'chronica 3000',
  description = 'barcelona based visual production collective. available worldwide.',
  ogImage = '/img/chronica-logo.png',
  matchChrome = true,
  pageClass,
} = Astro.props;

const fullTitle = title === 'chronica 3000' ? title : `${title} — chronica 3000`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://chronica3000.com').toString();

// The loading screen only mounts on the homepage. Inner pages don't have a
// hero video to wait on, so a loader there would just feel like an obstacle.
const showLoader = pageClass === 'page-home';
---

<!doctype html>
<html lang="en" class:list={[pageClass]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />
    {matchChrome && <meta name="theme-color" content="#0a0a0a" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/img/chronica-logo.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@700&family=Roboto+Mono:wght@300;400;500;600;700&display=swap" />

    {/* Section-restore on back navigation:
        If the URL has a hash (e.g. "/#highlight-fullmoon" returning from a project page),
        disable smooth-scroll for the initial paint so the browser jumps to that anchor
        instantly instead of animating from the top. Restore smooth scroll after load. */}
    <script is:inline>
      if (window.location.hash) {
        document.documentElement.style.scrollBehavior = 'auto';
        window.addEventListener('load', function () {
          // Explicitly land on the target section. On the homepage the scroll
          // container is <main> (not the document), and native fragment
          // scrolling into a nested scroller isn't guaranteed across browsers,
          // so we scroll the element into view ourselves. Inner pages where the
          // document scrolls are handled identically and correctly.
          try {
            var el = document.getElementById(decodeURIComponent(location.hash.slice(1)));
            if (el) el.scrollIntoView({ block: 'start' });
          } catch (e) {}
          requestAnimationFrame(function () {
            document.documentElement.style.scrollBehavior = '';
          });
        });
      }
    </script>

    {/* Loading screen — homepage only.
        Inlined here so it paints on the FIRST frame, before global.css
        downloads and parses. Black canvas with the chronica wordmark and a
        subtle pulsing rule. Fades when the hero video reports `canplay`
        (dispatched as `chronica:hero-ready`), or after a 3.5s safety timeout
        — whichever comes first. Returning from BFCache: removed instantly.
        Reduced motion: skipped entirely. */}
    {showLoader && (
      <style is:inline>
        {`
          #chronica-loader {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: #000;
            display: grid;
            place-items: center;
            transition: opacity 600ms ease;
            will-change: opacity;
          }
          #chronica-loader[data-hidden] {
            opacity: 0;
            pointer-events: none;
          }
          #chronica-loader img {
            width: clamp(120px, 18vw, 200px);
            height: auto;
            opacity: 0.95;
          }
          #chronica-loader::after {
            content: '';
            position: absolute;
            left: 50%;
            bottom: 22%;
            transform: translateX(-50%);
            width: 60px;
            height: 1px;
            background: rgba(255, 255, 255, 0.35);
            animation: chronicaLoadPulse 1.6s ease-in-out infinite;
          }
          @keyframes chronicaLoadPulse {
            0%, 100% { opacity: 0.2; transform: translateX(-50%) scaleX(0.6); }
            50%      { opacity: 0.9; transform: translateX(-50%) scaleX(1);   }
          }
          @media (prefers-reduced-motion: reduce) {
            #chronica-loader { display: none; }
          }
        `}
      </style>
    )}
  </head>
  <body>
    {showLoader && (
      <div id="chronica-loader" aria-hidden="true">
        <img src="/img/chronica-mark.png" alt="" width="160" height="38" fetchpriority="high" />
      </div>
      <script is:inline>
        (function () {
          var loader = document.getElementById('chronica-loader');
          if (!loader) return;
          var hidden = false;
          function hide() {
            if (hidden) return;
            hidden = true;
            loader.setAttribute('data-hidden', '');
            // Remove from DOM after the fade so it can never absorb taps or
            // hold a paint layer. Dispatch a follow-up event in case any
            // component wants to start its own animation post-loader.
            setTimeout(function () {
              if (loader.parentNode) loader.parentNode.removeChild(loader);
              try { document.dispatchEvent(new CustomEvent('chronica:loader-gone')); } catch (e) {}
            }, 700);
          }
          // Primary signal: the hero reports ready.
          document.addEventListener('chronica:hero-ready', hide, { once: true });
          // Safety net: never trap the user if the hero stalls (slow 3G, etc).
          setTimeout(hide, 3500);
          // Reduced motion: dismiss immediately.
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) hide();
          // BFCache: if the user navigates back to a cached page, the
          // browser may restore the DOM with the loader still mounted —
          // dismiss it instantly in that case.
          window.addEventListener('pageshow', function (e) {
            if (e.persisted) hide();
          });
        })();
      </script>
    )}
    <slot />
  </body>
</html>
