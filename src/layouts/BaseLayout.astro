---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Open Graph preview image — absolute or root-relative path. */
  ogImage?: string;
  /** Apply theme-color = bg so mobile chrome matches. */
  matchChrome?: boolean;
  /** Class applied to <html>. Pages opt into page-scoped behaviour (e.g. scroll-snap). */
  pageClass?: string;
}

const {
  title = 'chronica 3000',
  description = 'barcelona based visual production collective. available worldwide.',
  // Square 1200×1200 social card (black bg + white chronica wordmark).
  ogImage = '/img/chronica-og.png',
  matchChrome = true,
  pageClass,
} = Astro.props;

const fullTitle = title === 'chronica 3000' ? title : `${title} — chronica 3000`;
// Absolute base for canonical + social image. Crawlers (Google, Twitter,
// Slack, iMessage) require ABSOLUTE og:image / og:url URLs — relative paths
// are why the preview image was blank.
const site = Astro.site ?? 'https://chronica3000.com';
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImageUrl = new URL(ogImage, site).toString();

// Organization structured data — gives Google an explicit brand logo signal.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Chronica3000',
  url: 'https://chronica3000.com',
  logo: 'https://chronica3000.com/img/chronica-icon-512.png',
};
---

<!doctype html>
<html lang="en" class:list={[pageClass]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#000000" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph (Facebook, LinkedIn, Slack, iMessage, Google) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="chronica 3000" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content="chronica" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="chronica" />

    {/* Favicons + app icons — ALL the same chronica wordmark on black, so the
        browser tab, bookmarks, Google result icon, apple-touch, manifest and
        Organization logo are one single brand mark. */}
    <link rel="icon" type="image/png" sizes="48x48" href="/img/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />

    {/* PWA / install manifest */}
    <link rel="manifest" href="/site.webmanifest" />

    {/* Organization structured data (brand logo signal for Google) */}
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@700&family=Roboto+Mono:wght@300;400;500;600;700&display=swap" />

    {/* Section-restore on back navigation:
        If the URL has a hash (e.g. "/#highlight-fullmoon" returning from a project page),
        disable smooth-scroll for the initial paint so the browser jumps to that anchor
        instantly instead of animating from the top. Restore smooth scroll after load. */}
    <script is:inline>
      if (window.location.hash) {
        document.documentElement.style.scrollBehavior = 'auto';
        window.addEventListener('load', function () {
          // Explicitly land on the target section. On the homepage the scroll
          // container is <main> (not the document), and native fragment
          // scrolling into a nested scroller isn't guaranteed across browsers,
          // so we scroll the element into view ourselves. Inner pages where the
          // document scrolls are handled identically and correctly.
          try {
            var el = document.getElementById(decodeURIComponent(location.hash.slice(1)));
            if (el) el.scrollIntoView({ block: 'start' });
          } catch (e) {}
          requestAnimationFrame(function () {
            document.documentElement.style.scrollBehavior = '';
          });
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
